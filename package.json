{
  "name": "nutrition-app-backend",
  "version": "1.0.0",
  "description": "NutriSync backend - Sistema de nutrición",
  "main": "dist/server.js",
 "scripts": {
  "dev": "nodemon --exec ts-node src/server.ts",
  "build": "tsc",
  "start": "node dist/server.js",
  "typeorm": "ts-node ./node_modules/typeorm/cli.js",
  "migration:generate": "npm run typeorm migration:generate -- -d src/config/database.ts",
  "migration:run": "npm run typeorm migration:run -- -d src/config/database.ts",
  "migration:revert": "npm run typeorm migration:revert -- -d src/config/database.ts"
},
  "dependencies": {
    "argon2": "^0.31.1",
    "axios": "^1.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.1.14",
    "typeorm": "^0.3.19",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.19.43",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
